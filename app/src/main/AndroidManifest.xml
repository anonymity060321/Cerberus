<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/cerberus"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/cerberus_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Cerberus"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="33"
        tools:replace="android:allowBackup">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Cerberus">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".passkey.PasskeyCreateActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <activity
            android:name=".passkey.PasskeyGetActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <service
            android:name=".passkey.CerberusCredentialProviderService"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/cerberus"
            android:label="@string/passkey_provider_name"
            android:permission="android.permission.BIND_CREDENTIAL_PROVIDER_SERVICE">
            <intent-filter>
                <action android:name="android.service.credentials.CredentialProviderService" />
            </intent-filter>
            <meta-data
                android:name="android.credentials.provider"
                android:resource="@xml/credential_provider" />
        </service>

        <service
            android:name=".passkey.CerberusAutofillService"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/cerberus"
            android:label="@string/passkey_provider_name"
            android:permission="android.permission.BIND_AUTOFILL_SERVICE">
            <intent-filter>
                <action android:name="android.service.autofill.AutofillService" />
            </intent-filter>
            <meta-data
                android:name="android.autofill"
                android:resource="@xml/autofill_service" />
        </service>
    </application>

</manifest>
